{
  "manifest_version": 3,
  "name": "Land Listings Scraper",
  "version": "1.0.0",
  "description": "Scrape land listings from LandWatch, Lands of America, Zillow, and more. Export to CSV.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "https://www.landwatch.com/*",
    "https://www.landsofamerica.com/*",
    "https://www.zillow.com/*",
    "https://www.realtor.com/*",
    "https://www.landandfarm.com/*",
    "https://*.craigslist.org/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.landwatch.com/*",
        "https://www.landsofamerica.com/*",
        "https://www.zillow.com/*",
        "https://www.realtor.com/*",
        "https://www.landandfarm.com/*",
        "https://*.craigslist.org/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
