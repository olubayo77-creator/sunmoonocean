{
  "manifest_version": 3,
  "name": "PACER Chapter 13 Discharge Extractor",
  "version": "2.0.0",
  "description": "Extracts Chapter 13 discharged homeowners from CA, OR, CO PACER courts using CSO auto-login.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "https://pacer.psc.uscourts.gov/*",
    "https://pacer.login.uscourts.gov/*",
    "https://ecf.cacb.uscourts.gov/*",
    "https://ecf.caeb.uscourts.gov/*",
    "https://ecf.canb.uscourts.gov/*",
    "https://ecf.casb.uscourts.gov/*",
    "https://ecf.orb.uscourts.gov/*",
    "https://ecf.cob.uscourts.gov/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://ecf.cacb.uscourts.gov/*",
        "https://ecf.caeb.uscourts.gov/*",
        "https://ecf.canb.uscourts.gov/*",
        "https://ecf.casb.uscourts.gov/*",
        "https://ecf.orb.uscourts.gov/*",
        "https://ecf.cob.uscourts.gov/*",
        "https://pacer.psc.uscourts.gov/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
